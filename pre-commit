#!/bin/bash
# ============================================
# PRE-COMMIT HOOK: Block .env file commits
# Install: cp pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# ============================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Files that should NEVER be committed
BLOCKED_PATTERNS=(
    ".env"
    ".env.local"
    ".env.production"
    ".env.staging"
    ".env.development"
    "compose.env"
    "*.env.bak"
)

# Check staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

for file in $STAGED_FILES; do
    filename=$(basename "$file")
    
    # Check against blocked patterns
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        # Handle wildcards
        if [[ "$pattern" == *"*"* ]]; then
            if [[ "$filename" == ${pattern//\*/} ]]; then
                echo -e "${RED}BLOCKED: ${file}${NC}"
                echo -e "${YELLOW}This file appears to contain secrets!${NC}"
                echo -e "If this is an example file, rename it to .env.example"
                echo -e "To bypass (NOT recommended): git commit --no-verify"
                exit 1
            fi
        elif [[ "$filename" == "$pattern" ]]; then
            echo -e "${RED}BLOCKED: ${file}${NC}"
            echo -e "${YELLOW}This file appears to contain secrets!${NC}"
            echo -e "If this is an example file, rename it to .env.example"
            echo -e "To bypass (NOT recommended): git commit --no-verify"
            exit 1
        fi
    done
    
    # Also check file content for common secret patterns
    if [[ -f "$file" ]]; then
        if grep -qE '(API_KEY|SECRET|PASSWORD|TOKEN)=[A-Za-z0-9+/]{20,}' "$file" 2>/dev/null; then
            echo -e "${RED}POTENTIAL SECRET in: ${file}${NC}"
            echo -e "${YELLOW}File contains patterns that look like real secrets.${NC}"
            echo -e "Review the file before committing."
            echo -e "To bypass (NOT recommended): git commit --no-verify"
            exit 1
        fi
    fi
done

exit 0
